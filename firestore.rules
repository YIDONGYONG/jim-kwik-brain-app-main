rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidResult(data) {
      return data.keys().hasAll(['browserId', 'brainType', 'scores', 'createdAt']) &&
        data.keys().size() == 4 &&
        data.browserId is string && data.browserId.size() <= 64 &&
        data.brainType is string && data.brainType.size() <= 10 &&
        data.scores is map &&
        data.scores.keys().hasAll(['T', 'F', 'C', 'D']) &&
        data.scores.T is number &&
        data.scores.F is number &&
        data.scores.C is number &&
        data.scores.D is number &&
        data.createdAt == request.time;
    }
    
    match /results/{resultId} {
      // allow anyone to submit anonymous telemetry
      allow create: if isValidResult(request.resource.data);
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
